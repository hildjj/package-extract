{
  "include": ["lib/*.js"],

  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "outDir": "types",
    "rootDir": "lib",
    "target": "ES2021",
    "types": ["node"]
  }
}
